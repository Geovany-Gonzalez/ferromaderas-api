# Servidor (3001 si el 3000 está ocupado)
PORT=3001

# JWT - Cambiar en producción
JWT_SECRET=ferromaderas-jwt-secret-cambiar-en-produccion
NODE_ENV=development

# Base de datos PostgreSQL
# Opción 1 - Usuario dedicado (si lo creaste en pgAdmin):
#   DATABASE_URL="postgresql://ferromaderas_user:TU_PASSWORD@localhost:5432/ferromaderas"
# Opción 2 - Usuario postgres (para probar si ferromaderas_user falla):
#   DATABASE_URL="postgresql://postgres:TU_PASSWORD_POSTGRES@localhost:5432/ferromaderas"
# Si la contraseña tiene %, escríbelo como %25
DATABASE_URL="postgresql://usuario:password@localhost:5432/ferromaderas?schema=public"

# Google Analytics 4 (GA4) - Estadísticas del sitio
# ID numérico de la propiedad GA4 (ej: 123456789)
# Se obtiene en: analytics.google.com → Admin → Configuración de propiedad
GA4_PROPERTY_ID=
# Ruta al archivo JSON de credenciales de la cuenta de servicio de Google Cloud
# Se crea en: console.cloud.google.com → APIs y servicios → Credenciales → Cuenta de servicio
GOOGLE_APPLICATION_CREDENTIALS=./credentials/ga4-service-account.json

# CORS - Orígenes permitidos (comma-separated). Obligatorio con cookies HttpOnly.
# Local: http://localhost:4200
# Producción Vercel: https://tu-app.vercel.app (sin slash final). Varias URLs: separadas por coma.
CORS_ORIGIN=http://localhost:4200

# URL del frontend (para enlaces en emails)
FRONTEND_URL=http://localhost:4200

# Cookie JWT HttpOnly (nombre opcional)
# AUTH_COOKIE_NAME=fm_access_token

# Si el navegador llama al API en OTRO dominio sin proxy (ej. apiUrl absoluto en el front):
# AUTH_CROSS_ORIGIN=true  → SameSite=None (requiere HTTPS en producción).
# Con rewrite /api en Vercel hacia Railway (recomendado): dejalo en false / sin definir.
# AUTH_CROSS_ORIGIN=false

# Email - Para recuperar contraseña y enviar credenciales al crear usuario
# Si no se configura, los emails NO se envían (revisa la consola del API)
# Gmail: usa "Contraseña de aplicación" (no la contraseña normal)
#   → Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de app
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@correo.com
# SMTP_PASS=tu_app_password
# MAIL_FROM=noreply@ferromaderas.com

# API Key para sincronización de inventario (POST /api/products/bulk-sync)
# El .exe local envía este valor en el header X-API-Key
# INVENTORY_SYNC_API_KEY=

# -----------------------------------------------------------------------------
# Chatbot con IA (OpenAI)
# -----------------------------------------------------------------------------
# La API key vive SOLO aquí (backend). El navegador nunca la ve.
# Si NO se configura OPENAI_API_KEY, el chatbot funciona igual pero solo con
# las FAQs/preguntas prelistadas (sin IA y sin costo).
# Se obtiene en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Modelo a usar (económico por defecto)
# OPENAI_MODEL=gpt-4o-mini
# Máximo de tokens de la respuesta (controla longitud y costo)
# OPENAI_MAX_TOKENS=400
# Tope diario de tokens IA (entrada+salida). Al alcanzarlo: FAQs/respaldo + aviso en bitácora.
# 0 = sin tope diario. Default: 100000
# OPENAI_DAILY_TOKEN_LIMIT=100000
# URL base (cambiar solo si usas Azure OpenAI u otro compatible)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Precios por 1,000,000 de tokens (USD) para estimar el costo en el panel admin.
# Ajustá según el modelo elegido. Defaults aproximados de gpt-4o-mini:
# OPENAI_PRICE_INPUT_PER_1M=0.15
# OPENAI_PRICE_OUTPUT_PER_1M=0.60
