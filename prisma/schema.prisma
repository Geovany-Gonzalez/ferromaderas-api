// Prisma schema - Ferromaderas API
// Tablas en español en la base de datos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Roles y permisos
// ---------------------------------------------------------------------------
model Role {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("creado_en")

  users       User[]
  permissions RolePermission[]
  @@map("roles")
}

model Permission {
  id   String @id @default(uuid())
  slug String @unique
  name String

  roles RolePermission[]
  @@map("permisos")
}

model RolePermission {
  roleId       String @map("rol_id")
  permissionId String @map("permiso_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("rol_permisos")
}

// ---------------------------------------------------------------------------
// Usuarios
// ---------------------------------------------------------------------------
model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique
  passwordHash         String    @map("password_hash")
  name                 String
  phone                String?
  profileImage         String?   @map("profile_image")
  status               String    @default("activo")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  lastLoginAt          DateTime? @map("last_login_at")
  createdAt            DateTime  @default(now()) @map("creado_en")
  updatedAt            DateTime  @updatedAt @map("actualizado_en")

  roleId String @map("rol_id")
  role   Role   @relation(fields: [roleId], references: [id])

  @@map("usuarios")
}

// ---------------------------------------------------------------------------
// Categorías
// ---------------------------------------------------------------------------
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  imageUrl    String?  @map("imagen_url") @db.Text
  description String?  @map("descripcion") @db.Text
  active      Boolean  @default(true) @map("activo")
  parentId    String?  @map("padre_id")
  createdAt   DateTime @default(now()) @map("creado_en")
  updatedAt   DateTime @updatedAt @map("actualizado_en")

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@map("categorias")
}

// ---------------------------------------------------------------------------
// Productos
// ---------------------------------------------------------------------------
// Regla de negocio en BD (CHECK, migración productos_activo_requiere_catalogo):
// si activo=true → precio>0, categoría, imagen no vacía, pendiente_config=false.
// Mantener coherente con ProductsService.canBeActive.
model Product {
  id            String   @id @default(uuid())
  code          String   @unique @map("codigo")
  name          String
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?  @map("imagen_url")
  categoryId    String?  @map("categoria_id")
  active        Boolean  @default(true) @map("activo")
  featured      Boolean  @default(false) @map("destacado")
  pendingConfig Boolean  @default(false) @map("pendiente_config")
  stock         Int      @default(0) @map("existencia")
  createdAt     DateTime @default(now()) @map("creado_en")
  updatedAt     DateTime @updatedAt @map("actualizado_en")

  category Category? @relation(fields: [categoryId], references: [id])

  @@map("productos")
}

// ---------------------------------------------------------------------------
// Políticas de compra (página pública)
// ---------------------------------------------------------------------------
model PolicyPage {
  id       String   @id @default(uuid())
  title    String   @map("titulo")
  subtitle String   @map("subtitulo")
  sections PolicySection[]

  @@map("politica_pagina")
}

model PolicySection {
  id       String   @id @default(uuid())
  title   String   @map("titulo")
  content Json     @map("contenido") // array de strings
  iconUrl String?  @map("icono_url")
  order   Int      @default(0) @map("orden")

  pageId String     @map("pagina_id")
  page   PolicyPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("politica_seccion")
}

// ---------------------------------------------------------------------------
// Cotizaciones (generadas desde el carrito público, gestionadas en el panel)
// ---------------------------------------------------------------------------
// Los datos del cliente se guardan de forma denormalizada dentro de la
// cotización (el sitio público no requiere registro). El nombre y el precio
// del producto se copian en cada línea para conservar el histórico aunque el
// producto cambie o se elimine más adelante.
model Cotizacion {
  id            String   @id @default(uuid())
  codigo        String   @unique @map("codigo") // FM-YYYY-XXXX
  estado        String   @default("nueva") @map("estado") // nueva | en_seguimiento | confirmada | cerrada | cancelada
  clienteNombre String?  @map("cliente_nombre")
  clienteTelefono String? @map("cliente_telefono")
  clienteEmail  String?  @map("cliente_email")
  clienteDireccion String? @map("cliente_direccion") @db.Text
  clienteNota   String?  @map("cliente_nota") @db.Text
  // subtotal = suma bruta de líneas; total = subtotal - descuentoMonto (precio final).
  subtotal            Decimal  @default(0) @db.Decimal(12, 2)
  descuentoPorcentaje Decimal  @default(0) @map("descuento_porcentaje") @db.Decimal(5, 2)
  descuentoMonto      Decimal  @default(0) @map("descuento_monto") @db.Decimal(12, 2)
  descuentoMotivo     String?  @map("descuento_motivo") @db.Text
  total         Decimal  @default(0) @db.Decimal(12, 2)
  // Flujo de aprobación comercial: no_requiere | pendiente | aprobada | rechazada
  aprobacion        String    @default("no_requiere") @map("aprobacion")
  aprobadoPorId     String?   @map("aprobado_por_id")
  aprobadoPorNombre String?   @map("aprobado_por_nombre")
  aprobadoEn        DateTime? @map("aprobado_en")
  aprobacionNota    String?   @map("aprobacion_nota") @db.Text
  vendedorId    String?  @map("vendedor_id")
  vendedorNombre String? @map("vendedor_nombre")
  /** Usuario registrado (rol cliente) vinculado a esta cotización. */
  clienteRegistradoId String? @map("cliente_registrado_id")
  ip            String?  @map("ip")
  createdAt     DateTime @default(now()) @map("creado_en")
  updatedAt     DateTime @updatedAt @map("actualizado_en")

  items       CotizacionItem[]
  seguimiento SeguimientoCotizacion[]

  @@index([estado])
  @@index([aprobacion])
  @@index([clienteRegistradoId])
  @@index([clienteEmail])
  @@map("cotizaciones")
}

/** Historial de seguimiento comercial (Cap. III §3.4.3). */
model SeguimientoCotizacion {
  id              String   @id @default(uuid())
  cotizacionId    String   @map("cotizacion_id")
  tipo            String   @default("cambio_estado") @map("tipo")
  estadoAnterior  String?  @map("estado_anterior")
  estadoNuevo     String?  @map("estado_nuevo")
  comentario      String?  @db.Text
  usuarioId       String?  @map("usuario_id")
  usuarioNombre   String?  @map("usuario_nombre")
  createdAt       DateTime @default(now()) @map("creado_en")

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("seguimiento_cotizacion")
}

model CotizacionItem {
  id             String  @id @default(uuid())
  cotizacionId   String  @map("cotizacion_id")
  productoId     String? @map("producto_id")
  codigo         String  @map("codigo")
  nombre         String  @map("nombre")
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(10, 2)
  cantidad       Int     @map("cantidad")
  subtotal       Decimal @map("subtotal") @db.Decimal(12, 2)

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("cotizacion_items")
}

// ---------------------------------------------------------------------------
// Bitácora (auditoría para todo el sistema)
// ---------------------------------------------------------------------------
model Bitacora {
  id        String   @id @default(uuid())
  fecha     DateTime @default(now()) @map("fecha")
  modulo    String   @map("modulo")   // productos, usuarios, auth, inventario_sync, etc.
  accion    String   @map("accion")   // crear, actualizar, eliminar, sincronizar, login, etc.
  usuarioId String?  @map("usuario_id")
  detalles  Json?    @map("detalles") // JSON con datos adicionales
  ip        String?  @map("ip")

  @@map("bitacora")
}

// ---------------------------------------------------------------------------
// Chatbot (asistente del sitio público)
// ---------------------------------------------------------------------------
// Preguntas prelistadas/respuestas controladas que se editan desde el panel.
// Se usan tanto para los botones del chat como para responder SIN costo de IA
// cuando el mensaje del usuario coincide con una FAQ.
model ChatFaq {
  id        String   @id @default(uuid())
  question  String   @map("pregunta")
  answer    String   @map("respuesta") @db.Text
  // Palabras clave separadas por coma para el emparejamiento del texto libre.
  keywords  String?  @map("palabras_clave") @db.Text
  order     Int      @default(0) @map("orden")
  active    Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("creado_en")
  updatedAt DateTime @updatedAt @map("actualizado_en")

  @@map("chatbot_faq")
}

// Una conversación agrupa los mensajes de una sesión del navegador.
model ChatConversation {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  // Nombre que el visitante ingresa (opcional) para personalizar el trato.
  visitorName String?  @map("visitante_nombre")
  startedAt   DateTime @default(now()) @map("iniciada_en")
  lastAt      DateTime @updatedAt @map("ultima_en")
  ip          String?  @map("ip")
  userAgent   String?  @map("user_agent") @db.Text

  messages ChatMessage[]

  @@index([sessionId])
  @@map("chatbot_conversacion")
}

// Cada mensaje del historial. Guardamos tokens de IA para medir el consumo/costo.
model ChatMessage {
  id               String   @id @default(uuid())
  conversationId   String   @map("conversacion_id")
  role             String   @map("rol")        // 'user' | 'assistant'
  content          String   @map("contenido") @db.Text
  source           String?  @map("fuente")     // 'faq' | 'ia' | 'fallback'
  promptTokens     Int      @default(0) @map("tokens_entrada")
  completionTokens Int      @default(0) @map("tokens_salida")
  createdAt        DateTime @default(now()) @map("creado_en")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chatbot_mensaje")
}
